{
    "name": "Zolinga Internationalization",
    "version": "2.6.0",
    "description": "Provides internationalization support for Zolinga applications.",
    "authors": [
        "Daniel Sevcik <danny@zolinga.net>"
    ],
    "attributes": {},
    "listen": [
        {
            "description": "Provides internationalization services and information about locale.",
            "service": "locale",
            "class": "Zolinga\\Intl\\LocaleService",
            "origin": [
                "internal"
            ]
        },
        {
            "description": "Locale initialization, namely gettext catalog initialization.",
            "event": "system:start",
            "class": "Zolinga\\Intl\\LocaleService",
            "method": "onSystemStart",
            "origin": [
                "internal"
            ],
            "priority": 0.9
        },
        {
            "description": "Provides gettext domain discovery and i18n workflow services.",
            "service": "i18n",
            "class": "Zolinga\\Intl\\I18nService",
            "origin": [
                "internal"
            ]
        },
        {
            "description": "Provides AI-powered translation service.",
            "service": "translator",
            "class": "Zolinga\\Intl\\TranslatorService",
            "origin": [
                "internal"
            ]
        },
        {
            "description": "Handles completed async AI translations and dispatches the callback TranslateEvent.",
            "event": "i18n:translation:done",
            "class": "Zolinga\\Intl\\TranslatorService",
            "method": "onTranslation",
            "origin": [
                "internal"
            ]
        },
        {
            "description": "CLI interface for gettext extraction.",
            "event": "gettext:extract",
            "class": "Zolinga\\Intl\\GettextCli",
            "method": "extract",
            "origin": [
                "cli"
            ]
        },
        {
            "description": "CLI interface for gettext compilation.",
            "event": "gettext:compile",
            "class": "Zolinga\\Intl\\GettextCli",
            "method": "compile",
            "origin": [
                "cli"
            ]
        },
        {
            "description": "CLI interface for AI-powered autotranslation of untranslated gettext entries.",
            "event": "gettext:autotranslate",
            "class": "Zolinga\\Intl\\GettextCli",
            "method": "autotranslate",
            "origin": [
                "cli"
            ]
        },
        {
            "description": "CLI pipeline: extract, autotranslate, and compile in one step.",
            "event": "autotranslate",
            "class": "Zolinga\\Intl\\AutotranslateCli",
            "method": "run",
            "origin": [
                "cli"
            ]
        },
        {
            "description": "Handles <language-selector/> content tag to render a language switcher.",
            "event": "cms:content:language-selector",
            "class": "Zolinga\\Intl\\LanguageSelectorListener",
            "method": "handle",
            "origin": [
                "internal"
            ]
        }
    ],
    "emit": [],
    "webComponents": [
        {
            "tag": "language-selector",
            "description": "Language selector with popup.",
            "module": "web-components/language-selector/language-selector.js"
        }
    ],
    "autoload": {
        "Zolinga\\Intl\\": "src/"
    },
    "config": {
        "intl": {
            "# locales": "List of supported locales in the application.",
            "locales": [
                "en_US"
            ],
            "translate": {
                "# instructions": "Per-language translation instructions for AI-powered autotranslate feature. It will always be added to the translation context. Key '*' applies to all languages. Value: text instructions or Zolinga file path.",
                "instructions": {
                    "*": "config://zolinga-intl/translate-prompt-all.md",
                    "en_US": "Do not translate English to English."
                }
            }
        },
        "ai": {
            "backends": {
                "# translator": "Used by zolinga-intl module to perform AI-powered translations",
                "translator": {
                    "model": "translategemma"
                }
            }
        }
    }
}